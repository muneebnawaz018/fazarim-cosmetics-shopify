{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "vendor": {
          "type": "text",
          "settings": {
            "text": "{{ product.vendor }}",
            "text_style": "uppercase"
          }
        },
        "title": {
          "type": "title"
        },
        "rating": {
          "type": "rating",
          "settings": {}
        },
        "price": {
          "type": "price"
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button",
            "swatch_shape": "circle"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": true
          }
        },
        "description": {
          "type": "description"
        },
        "tab_ingredients": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Ingredients",
            "icon": "leaf",
            "content": "<p>Ingredient list for this product is being finalised. Contact ceo@fazarim.com if you need it before ordering.</p>",
            "page": "",
            "product_metafield": "ingredients"
          }
        },
        "tab_how_to": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "How to use",
            "icon": "check_mark",
            "content": "<p>See the product packaging for directions. Patch test before first use.</p>",
            "page": "",
            "product_metafield": "how_to_use"
          }
        },
        "tab_shipping": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Shipping & returns",
            "icon": "truck",
            "content": "<p>Free shipping on orders over Rs. 10,000. Standard delivery is Rs. 250 (3\u20135 business days). We deliver within Pakistan only.</p><p>Unopened items can be returned within 7 days. For hygiene reasons, opened products cannot be returned unless faulty.</p>",
            "page": ""
          }
        },
        "trust": {
          "type": "icon-with-text",
          "settings": {
            "layout": "horizontal",
            "icon_1": "check_mark",
            "heading_1": "Dermatologist Approved",
            "icon_2": "leaf",
            "heading_2": "Sulphate-Free",
            "icon_3": "heart",
            "heading_3": "Cruelty-Free"
          }
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Share"
          }
        }
      },
      "block_order": [
        "vendor",
        "title",
        "rating",
        "price",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "description",
        "tab_ingredients",
        "tab_how_to",
        "tab_shipping",
        "trust",
        "share"
      ],
      "settings": {
        "enable_sticky_info": true,
        "color_scheme": "scheme-1",
        "media_position": "left",
        "gallery_layout": "thumbnail_slider",
        "media_size": "large",
        "constrain_to_viewport": true,
        "media_fit": "contain",
        "image_zoom": "lightbox",
        "mobile_thumbnails": "show",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 36,
        "padding_bottom": 12
      }
    },
    "complementary": {
      "type": "featured-collection",
      "settings": {
        "title": "Pairs well with",
        "heading_size": "h2",
        "collection": "all",
        "products_to_show": 4,
        "columns_desktop": 4,
        "color_scheme": "scheme-2",
        "full_width": false,
        "show_view_all": false,
        "enable_desktop_slider": true,
        "swipe_on_mobile": true,
        "image_ratio": "portrait",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": true,
        "quick_add": "standard",
        "columns_mobile": "2",
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "You may also like",
        "heading_size": "h2",
        "products_to_show": 4,
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "image_ratio": "portrait",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": true,
        "columns_mobile": "2",
        "padding_top": 36,
        "padding_bottom": 28
      }
    }
  },
  "order": [
    "main",
    "complementary",
    "related-products"
  ]
}
