# Copy to .shopify.env (gitignored) and fill in.
# Get the token: Shopify Admin → Settings → Apps and sales channels
#   → Develop apps → Create an app → Configure Admin API scopes
#   → install → "Reveal token once"
#
# Required Admin API scopes:
#   read_products, write_products              (products + collections)
#   read_online_store_navigation, write_online_store_navigation   (nav menus)
#   read_files, write_files                    (image uploads)
#
# NEVER commit .shopify.env. Revoke by uninstalling the app in Admin.

SHOPIFY_STORE=fazarim-cosmetics.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-01
